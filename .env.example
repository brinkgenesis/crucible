# ==== Required ====
ANTHROPIC_API_KEY=sk-ant-...           # Your Anthropic API key
SECRET_KEY_BASE=                       # generate with: mix phx.gen.secret

# DATABASE_URL — pick one:
#   Native Postgres (recommended — `brew install postgresql@16`):
DATABASE_URL=postgresql://localhost:5432/crucible
#   Docker Postgres (`docker compose up -d postgres`, host port 55432):
# DATABASE_URL=postgresql://crucible:crucible@localhost:55432/crucible

# ==== GitHub (required for PR shepherd + CI log ingestor + inbox Github ingester) ====
GITHUB_TOKEN=ghp_...                   # Needs repo + pull_requests scopes
GITHUB_OWNER=                          # Default org/user for CI log + inbox ingestion
GITHUB_REPO=                           # Default repo for CI log + inbox ingestion
# GITHUB_INGEST_STATE=open             # Inbox Github ingester: open | closed | all
# GITHUB_INGEST_SINCE=                  # ISO8601 cutoff for incremental polls

# ==== Inbox ingesters ====
# RSS: comma-separated list of feed URLs. Unset = skip.
# INBOX_RSS_FEEDS=https://news.example.com/rss,https://blog.example.com/feed
# Webhook: HMAC-SHA256 secret for POST /api/v1/webhooks/inbox/receive.
# Unset = accept unsigned payloads (dev only).
# INBOX_WEBHOOK_SECRET=

# ==== Server ====
PHX_HOST=localhost
PORT=4801
PHX_SERVER=true

# ==== Optional: extra model providers ====
GOOGLE_API_KEY=                        # Gemini routing
MINIMAX_API_KEY=                       # MiniMax M2 routing
OPENAI_API_KEY=                        # Future OpenAI adapter
OPENROUTER_API_KEY=                    # OpenRouter aggregator
TOGETHER_API_KEY=                      # Together.ai
OLLAMA_BASE_URL=http://localhost:11434 # Local model fallback

# ==== Sandbox (workload isolation) ====
# Two independent knobs. BOTH needed for real container isolation.
SANDBOX_ENABLED=true                   # Activate sandbox code path (default: true)
SANDBOX_MODE=local                     # local | docker — use "docker" for real isolation
SANDBOX_POOL_SIZE=3                    # Warm Docker containers kept ready
SANDBOX_IMAGE=node:22-alpine
SANDBOX_POLICY=standard                # strict | standard | permissive

# ==== Secrets provider ====
# Default reads env vars directly. For production on AWS, uncomment below.
SECRETS_PROVIDER=env                   # env | aws
# AWS_REGION=us-west-2
# AWS_SECRET_NAME=crucible/prod

# ==== Dashboard auth (optional) ====
DASHBOARD_AUTH=false                   # Set true to require Google OAuth
OAUTH_ALLOWED_DOMAIN=                  # Restrict to a single GSuite domain
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ==== Budget ====
DAILY_BUDGET_LIMIT_USD=100
RUN_BUDGET_LIMIT_USD=10

# ==== Self-improvement ====
SELF_IMPROVE_ENABLED=true              # Learn from each run's KPIs
SELF_IMPROVE_MIN_INTERVAL_MS=60000
SELF_IMPROVE_LOOKBACK_HOURS=24

# ==== Alerting (optional) ====
ALERTING_ENABLED=false
# ALERT_WEBHOOK_URL=                   # Slack / PagerDuty / Teams webhook
# ALERT_WEBHOOK_FORMAT=slack           # generic | slack | pagerduty | teams
# ALERT_BUDGET_WARNING_PCT=80
# ALERT_FAILURE_RATE_PCT=25

# ==== Rate limits (per-IP and per-tenant, requests/min) ====
RATE_LIMIT_IP_READ=120
RATE_LIMIT_IP_WRITE=20
RATE_LIMIT_TENANT_READ=300
RATE_LIMIT_TENANT_WRITE=60

# ==== Clustering (multi-node) ====
CLUSTER_STRATEGY=gossip                # gossip (dev) | dns (prod) | k8s

# ==== Observability (optional) ====
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=crucible
# SENTRY_DSN=
